##
# Python backend server and Llama.cpp configuration env
##

# --- Classifier Configuration ---
# URL of the Llama.cpp server running the classifier model (OpenAI-compatible)
CLASSIFIER_ENDPOINT=http://localhost:8080/v1
# Model name/alias (must match the loaded model in Llama.cpp via --alias)
CLASSIFIER_MODEL=qwen3-14b
# Temperature (keep low for consistent classification)
CLASSIFIER_TEMPERATURE=0.1

# --- Server Settings ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- Model Tiers ---
# Map complexity levels to specific model IDs/names available in your inference backend
TIER_SIMPLE_MODEL=qwen-1.5b
TIER_THINKING_MODEL=qwen-7b
TIER_COMPLEX_MODEL=qwen-72b

# --- Chunking Options ---
CHUNKING_STRATEGY=semantic
# Token threshold to trigger chunking
CHUNKING_THRESHOLD=8000
# Max chunk size (tokens)
CHUNKING_MAX_SIZE=4096
# Overlap between chunks (tokens)
CHUNKING_OVERLAP=200
